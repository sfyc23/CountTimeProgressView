<?xml version="1.0" encoding="utf-8"?>
<resources>
    <declare-styleable name="CountTimeProgressView">

        <attr name="backgroundColorCenter" format="color" />
        <attr name="borderWidth" format="dimension" />
        <attr name="borderDrawColor" format="color" />
        <attr name="borderBottomColor" format="color" />

        <attr name="markBallWidth" format="dimension" />
        <attr name="markBallColor" format="color" />
        <attr name="markBallFlag" format="boolean" />

        <attr name="startAngle" format="float" />
        <attr name="clockwise" format="boolean" />

        <attr name="countTime" format="integer"/>

        <attr name="textStyle" format="enum">
            <enum name="jump" value="0" />
            <enum name="second" value="1" />
            <enum name="clock" value="2" />
            <enum name="none" value="3" />
        </attr>

        <attr name="titleCenterText" format="string"/>
        <attr name="titleCenterColor" format="color"/>
        <attr name="titleCenterSize" format="dimension" />

        <!-- 2.0 新增属性 -->
        <attr name="autoStart" format="boolean" />
        <attr name="finishedText" format="string" />
        <attr name="showCenterText" format="boolean" />
        <attr name="strokeCap" format="enum">
            <enum name="butt" value="0" />
            <enum name="round" value="1" />
            <enum name="square" value="2" />
        </attr>
        <attr name="gradientStartColor" format="color" />
        <attr name="gradientEndColor" format="color" />

        <!-- v2.1 新增属性：阈值提醒 -->
        <attr name="warningTime" format="integer" />
        <attr name="warningColor" format="color" />

        <!-- v2.1 新增属性：跳过延迟 -->
        <attr name="clickableAfter" format="integer" />
        <attr name="disabledText" format="string" />

    </declare-styleable>
</resources>
