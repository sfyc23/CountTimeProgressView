<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="@null"
        android:scaleType="centerCrop"
        android:src="@mipmap/peaty" />

    <com.sfyc.ctpv.CountTimeProgressView
        android:id="@+id/countTimeProgressView1"
        android:layout_width="84dp"
        android:layout_height="84dp"
        android:layout_alignParentEnd="true"
        android:paddingTop="16dp"
        android:paddingEnd="16dp"
        app:backgroundColorCenter="#88000000"
        app:borderBottomColor="#80FFFFFF"
        app:borderDrawColor="#FFFFFF"
        app:borderWidth="3dp"
        app:clickableAfter="2000"
        app:countTime="5000"
        app:disabledText="@string/text_please_wait"
        app:finishedText="@string/text_enter"
        app:markBallColor="#FFFFFF"
        app:markBallFlag="true"
        app:markBallWidth="3dp"
        app:strokeCap="round"
        app:textStyle="jump"
        app:titleCenterColor="#FFFFFF"
        app:titleCenterSize="11sp"
        app:titleCenterText="@string/text_skip" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="48dp"
        android:gravity="center"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="v2.1.0"
            android:textColor="#B0FFFFFF"
            android:textSize="14sp" />
    </LinearLayout>

</RelativeLayout>
