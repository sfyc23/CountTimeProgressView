<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/phone_masked"
        android:textColor="@color/text_primary"
        android:textSize="16sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:gravity="center_vertical">

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="@string/hint_verification_code">

            <com.google.android.material.textfield.TextInputEditText
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:maxLength="6" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.sfyc.ctpv.CountTimeProgressView
            android:id="@+id/ctpv_verify"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_marginStart="12dp"
            app:backgroundColorCenter="@color/background_page"
            app:borderBottomColor="#E0E0E0"
            app:borderDrawColor="@color/colorPrimary"
            app:borderWidth="3dp"
            app:countTime="60000"
            app:markBallFlag="false"
            app:strokeCap="round"
            app:textStyle="second"
            app:titleCenterColor="@color/text_primary"
            app:titleCenterSize="13sp"
            app:warningColor="@color/warning"
            app:warningTime="10000" />
    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_resend"
        style="@style/Widget.Material3.Button.TextButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:enabled="false"
        android:text="@string/action_resend_initial" />

    <TextView
        android:id="@+id/tv_tick_log"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:layout_weight="1"
        android:background="#F5F5F5"
        android:fontFamily="monospace"
        android:padding="12dp"
        android:scrollbars="vertical"
        android:textSize="12sp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_send"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/action_send_code" />

</LinearLayout>
